# ============================================
# Android / Kotlin Project .gitignore
# ============================================

# --- Gradle ---
.gradle/
build/
local.properties

# --- Android Studio / IDE ---
*.iml
.idea/
.externalNativeBuild
.cxx
/captures

# --- Kotlin ---
.kotlin/

# --- Android Artifacts ---
*.apk
*.aab
*.ap_
*.dex
**/build/outputs/
output-metadata.json

# --- Compiled / JVM ---
*.class
*.jar
!gradle/wrapper/gradle-wrapper.jar
*.war
*.nar
*.ear

# --- Temp Folders ---
.tmp/
tmp/
.temp/
temp/

# --- Secrets & Signing ---
*.jks
*.keystore
keystore.properties
.env
.env.*
google-services.json


# --- Coverage & Reports ---
*.exec
jacoco/

# --- OS Files ---
.DS_Store
Thumbs.db
ehthumbs.db
Desktop.ini

# --- Archives ---
*.zip
*.tar.gz
*.rar

# --- Crash Logs ---
hs_err_pid*
replay_pid*
*.hprof

# --- Misc ---
*.ctxt
.mtj.tmp/
*.log

# --- Beads (issue tracker) ---
.dolt/
*.db

# --- Lefthook ---
.lefthook-local/

# bv (beads viewer) local config and caches
.bv/
